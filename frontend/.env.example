# For local development, leave this blank/unset — the Vite dev server proxy
# (see vite.config.js) forwards /api requests to your local backend automatically.

# For production (Vercel/Netlify), set this to your deployed backend URL + /api
# e.g. VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=
