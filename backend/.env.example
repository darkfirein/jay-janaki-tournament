# Copy this file to .env and change the values

# Postgres connection string — get this free from neon.tech (see README for steps)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret key used to sign login tokens - change this to any long random string.
# REQUIRED in production: if this is left unset when NODE_ENV=production, the
# server now refuses to start rather than fall back to the default in the
# source code (anyone could otherwise forge an admin login with that default).
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port the backend server runs on
PORT=5000

# First admin account - created automatically the first time the server starts
ADMIN_GAME_UID=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Your deployed frontend URL (used for eSewa/Khalti redirect links and CORS)
FRONTEND_URL=http://localhost:5173

# eSewa (defaults below are eSewa's own public sandbox test credentials)
ESEWA_MODE=test
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# Khalti — get these from https://admin.khalti.com (test mode) or your live merchant dashboard
KHALTI_MODE=test
KHALTI_SECRET_KEY=

# Google Cloud Vision API key — used to OCR match-result screenshots and pay
# kill bonuses automatically. Get one from https://console.cloud.google.com:
# 1. Create/select a project, enable "Cloud Vision API"
# 2. Go to APIs & Services -> Credentials -> Create Credentials -> API key
# 3. (Recommended) Restrict the key to only the Cloud Vision API
GOOGLE_VISION_API_KEY=

# Cloudinary — used to store uploaded images (payment screenshots, tournament
# banners, QR code, announcement photos) so they survive server restarts and
# redeploys. WITHOUT these, uploads fall back to the local backend/uploads/
# folder, which is fine for local dev but is WIPED on every restart/redeploy
# on Render's free tier — so setting these up is strongly recommended for
# production. Get a free account + these three values from
# https://cloudinary.com/console (Dashboard page, no card required):
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push (real phone/browser notifications, delivered even when the site
# isn't open). These are a "VAPID" key pair that identifies your server to
# push services (Chrome/Firefox/etc) — NOT tied to any external account, so
# no signup needed. A working pair is filled in below so this feature works
# out of the box; generate your own anytime with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# If you regenerate them, every user's existing subscription becomes invalid
# and they'll need to re-enable notifications once from Settings.
VAPID_PUBLIC_KEY=BGIcYjtVo0whbuq6UNIg0py-HjWvEMvBdIWmCaPpjts7LYv1b7My8_cmsmRVdoqz0rPEKBkcQ3-3v4ZfMp5Cnf4
VAPID_PRIVATE_KEY=mQfISPG8kgHXQ1_qyV8D5JMyx85sHo4zhYe7oJkoInM
VAPID_SUBJECT=mailto:admin@jay-janaki-tournament.online
